<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.financetracker.controller.MainController">

    <top>
        <HBox styleClass="top-bar" spacing="10">
            <padding>
                <Insets top="16" right="20" bottom="16" left="20"/>
            </padding>
            <Label fx:id="titleLabel" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="18" styleClass="content-area">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <HBox spacing="16">
                <VBox styleClass="summary-card" spacing="6">
                    <Label text="Current Balance" styleClass="summary-title"/>
                    <Label fx:id="balanceLabel" text="€ 0.00" styleClass="summary-value"/>
                </VBox>

                <VBox styleClass="summary-card" spacing="6">
                    <Label text="Total Income" styleClass="summary-title"/>
                    <Label fx:id="incomeLabel" text="€ 0.00" styleClass="summary-value income-value"/>
                </VBox>

                <VBox styleClass="summary-card" spacing="6">
                    <Label text="Total Expenses" styleClass="summary-title"/>
                    <Label fx:id="expenseLabel" text="€ 0.00" styleClass="summary-value expense-value"/>
                </VBox>
            </HBox>

            <VBox spacing="12" styleClass="form-card">
                <Label text="Add Transaction" styleClass="section-title"/>

                <GridPane hgap="12" vgap="12">
                    <ComboBox fx:id="typeComboBox" prefWidth="140" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="categoryField" promptText="Category" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="amountField" promptText="Amount" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <TextField fx:id="dateField" promptText="Date (YYYY-MM-DD)" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                    <TextField fx:id="descriptionField" promptText="Description" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                    <Button text="Add" onAction="#handleAddTransaction" styleClass="primary-button" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                </GridPane>
            </VBox>

            <Label text="Recent Transactions" styleClass="section-title"/>

            <TableView fx:id="transactionTable" prefHeight="460">
                <columns>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="160"/>
                    <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="140"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="480"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>